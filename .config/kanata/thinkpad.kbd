(defcfg
  process-unmapped-keys yes
  linux-dev /dev/input/by-path/platform-i8042-serio-0-event-kbd
)
(defsrc
  caps lalt lmet
)
(deffakekeys
  ctrl-mode lctl
)
(defalias
  caps-ctrl (multi (on-press-fakekey ctrl-mode press) (on-release-fakekey ctrl-mode release))
)
(deflayer base
  @caps-ctrl lmet lalt
)
